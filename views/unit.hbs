<div class="row">
    <div class="col s12 m12">
        <div class="card">
            <form id="unit-name-form" data-method="PATCH" action="/units/unit/{{unit._id}}">
                <div class="card-content">
                    <div class="row">
                        <div class="col s3">
                            <div
                                style="width:100%; height:140px; display:flex; align-items:center; justify-content:center; background:#e3f2fd;">
                            <i class="ra ra-double-team" style="font-size:28px; color:#1565c0"></i>
                            </div>
                            <div style="margin-top:8px; text-align:center">
                                <div class="grey-text text-darken-1">Unit Profile</div>
                            </div>
                        </div>
                        <div class="col s9">
                            <div style="flex-grow:1">
                                <div class="row">
                                    <div class="col s3">
                                        <span class="card-title" style="margin:0">
                                            {{> field_select list=(unitTypes) selected=unit.type id="type" name="type" label="Type"}}
                                        </span>
                                    </div>
                                    <div class="col s9">
                                        <span class="card-title" style="margin:0">
                                            <div class="input-field">
                                                <input id="name" name="name" type="text" value="{{unit.name}}" required>
                                                <label for="name" class="active">Name</label>
                                            </div>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row" style="margin-bottom:0">
                        <div class="col s12">
                            <div class="input-field">
                            </div>
                        </div>
                        <div class="col s12">
                            <div class="input-field">
                                <textarea id="description" name="description" class="materialize-textarea" rows="2"
                                    style="min-height:48px">{{unit.description}}</textarea>
                                <label for="description" class="active">Description</label>
                            </div>
                        </div>
                        <div class="col s6">
                            {{> field label="Gold" name="gold" type="number" value=unit.gold required=true}}
                        </div>
                        <div class="col s6">
                            {{> field label="Experience" name="experience" type="number" value=unit.experience required=true}}
                        </div>
                        <div class="col s6">
                            {{> field label="Max Count In Warband (0 = no limit)" name="maxCount" type="number" value=unit.maxCount required=true}}
                        </div>
                        <div class="col s6" style="margin-top:18px;">
                            <label>
                                <input type="checkbox" id="isUnique" name="isUnique" {{#if unit.isUnique}}checked{{/if}}>
                                <span>Unique unit (can only be purchased once ever)</span>
                            </label>
                        </div>
                        <div class="col s12">
                            {{> field_select_multi list=skillTypeList selected=unit.skillAccess id="skillAccess" name="skillAccess" label="Skill Access"}}
                        </div>
                        <div class="col s12">
                            {{> field_select_multi list=itemList selected=unit.items id="items" name="items" label="Allowed Items"}}
                        </div>
                        <div class="col s12" style="margin-top:6px;">
                            <div class="row" style="margin-bottom:0;">
                                <div class="col s12 m8">
                                    {{#if copySourceUnits.length}}
                                    <div class="input-field">
                                        <select id="sourceUnitId" name="sourceUnitId" required>
                                            <option value="" disabled selected>Select Copy Item Restrictions From</option>
                                            {{#each copySourceUnits}}
                                            <option value="{{this._id}}">{{this.name}}</option>
                                            {{/each}}
                                        </select>
                                        <label for="sourceUnitId" class="active">Copy Item Restrictions From</label>
                                    </div>
                                    {{else}}
                                    <small class="grey-text">No other units available to copy from.</small>
                                    {{/if}}
                                </div>
                                <div class="col s12 m4" style="margin-top:18px;">
                                    {{#if copySourceUnits.length}}
                                    <button id="copy-items-btn" class="btn-small blue-grey darken-1 waves-effect waves-light" type="button">
                                        <i class="fa fa-copy"></i>
                                        Copy Items
                                    </button>
                                    <div id="copy-items-result" class="grey-text text-darken-1" style="font-size:0.8rem; margin-top:6px;"></div>
                                    {{/if}}
                                </div>
                            </div>
                        </div>

                        {{> stat_block_form unit=unit}}
                    </div>
                    <span class="grey-text text-darken-1" style="margin-right:12px">
                        Last updated:
                        {{formatDateTime unit.updatedAt}}
                    </span>
                </div>
                <div class="card-action blue lighten-5">
                    <div class="row" style="margin-bottom:0">
                        <div class="col s6">
                            <div class="col s6">
                                <a class="btn-small blue" href="/units/unit/{{unit._id}}/traits">Traits</a>
                            </div>
                        </div>
                        <div class="col s6 right-align">
                            <div class="btn-area">
                                <button id="delete-unit-btn" type="button" class="btn waves-effect waves-light red"
                                    title="Delete unit">
                                    <i class="ra ra-tombstone"></i>
                                </button>
                                <button class="btn waves-effect waves-light" type="submit">
                                    <i class="ra ra-save"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        var copyBtn = document.getElementById('copy-items-btn');
        var sourceSelect = document.getElementById('sourceUnitId');
        var resultEl = document.getElementById('copy-items-result');
        if (!copyBtn || !sourceSelect) return;

        copyBtn.addEventListener('click', function () {
            var sourceUnitId = sourceSelect.value;
            if (!sourceUnitId) {
                if (resultEl) {
                    resultEl.innerText = 'Select a source unit first.';
                    resultEl.style.color = '#c62828';
                }
                return;
            }

            if (resultEl) {
                resultEl.innerText = 'Copying...';
                resultEl.style.color = '#455a64';
            }

            $.ajax({
                url: '/units/unit/{{unit._id}}/items/copy',
                method: 'PATCH',
                dataType: 'json',
                data: { sourceUnitId: sourceUnitId },
                xhrFields: { withCredentials: true }
            }).done(function () {
                window.location.reload();
            }).fail(function (jqXHR) {
                var msg = 'Copy failed.';
                try {
                    var parsed = JSON.parse(jqXHR.responseText || '{}');
                    if (parsed && parsed.error) msg = parsed.error;
                } catch (e) {}
                if (resultEl) {
                    resultEl.innerText = msg;
                    resultEl.style.color = '#c62828';
                }
            });
        });
    })();
</script>