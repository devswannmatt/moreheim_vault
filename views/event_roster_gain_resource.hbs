<form id="create-roster-gain-resource-form" data-method="POST" data-redirect="close" action="/rosters/roster/{{roster._id}}/event/gainresource">
    <div class="row">
        <div class="col s4">
            <div class="input-field">
                <select id="resource-type" name="resource.type" required>
                    {{#each resourceTypes}}
                    <option value="{{this.value}}">{{this.value}} - {{this.label}}</option>
                    {{/each}}
                </select>
                <label for="resource-type">Resource Type</label>
            </div>
        </div>
        <div class="col s4">
            <div class="input-field">
                <input id="resource-quantity" name="resource.quantity" type="number" min="1" step="1" value="1" required>
                <label for="resource-quantity" class="active">Quantity</label>
            </div>
        </div>
        <div class="col s4">
            <div class="input-field">
                <input id="resource-roster" type="text" value="{{roster.name}}" disabled>
                <label for="resource-roster" class="active">Roster</label>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col s12">
            <div class="input-field">
                <input id="resource-description" name="description" type="text">
                <label for="resource-description">Notes</label>
            </div>
        </div>
    </div>
    <button class="btn waves-effect waves-light" type="submit">Create Event</button>
    <a href="#!" class="btn waves-effect waves-light red" type="button" onclick="closeModal(); return false;">Cancel</a>
</form>
