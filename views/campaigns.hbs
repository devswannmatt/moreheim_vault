<div class="section">
    <h3>Campaigns</h3>

    <div class="col-8 col-md-8">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Campaigns</span>
                <p>Manage campaigns in your campaigns.</p>
            </div>
        </div>
    </div>
    <div class="col-4 col-md-4">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Create Campaign</span>
                <form id="create-campaign-form" method="POST" action="/campaigns/create">
                    <div class="input-field">
                        <input id="name" name="name" type="text" required>
                        <label for="name">Name</label>
                    </div>
                    <div class="input-field">
                        <select id="privacy" name="privacy">
                            <option value="public" selected>Public — anyone can view</option>
                            <option value="private">Private — members only</option>
                        </select>
                        <label for="privacy">Visibility</label>
                    </div>
                    <button class="btn waves-effect waves-light" type="submit">Create Campaign</button>
                </form>
            </div>
        </div>
    </div>

    <table class="striped responsive-table" id="items-table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Visibility</th>
            <th>Created</th>
        </tr>
        </thead>
        <tbody>
        {{#each campaigns}}
            <tr>
                <td>{{{link this.name (concat '/campaigns/campaign/' this._id)}}}</td>
                <td>
                    {{#ifEq this.privacy "private"}}
                    <span style="font-size:0.8rem;color:#a93226;"><i class="fa fa-lock"></i> Private</span>
                    {{else}}
                    <span style="font-size:0.8rem;color:#1e6e35;"><i class="fa fa-globe"></i> Public</span>
                    {{/ifEq}}
                </td>
                <td>{{formatDateTime this.createdAt}}</td>
            </tr>
        {{/each}}
        </tbody>
    </table>
</div>

<script src="/js/campaigns.js"></script>
